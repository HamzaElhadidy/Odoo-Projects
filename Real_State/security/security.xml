<odoo>
    <!-- ========================================= -->
    <!-- MODULE CATEGORY -->
    <!-- ========================================= -->
    <record id="property_category" model="ir.module.category">
        <field name="name">Real Estate</field>
        <field name="description">Manage real estate properties and contracts</field>
        <field name="sequence">10</field>
    </record>

    <!-- ========================================= -->
    <!-- GROUPS -->
    <!-- ========================================= -->
    <record id="property_agent_group" model="res.groups">
        <field name="name">Property Agent</field>
        <field name="category_id" ref="property_category"/>
        <field name="comment">Can create and edit own properties only</field>
    </record>

    <record id="property_manager_group" model="res.groups">
        <field name="name">Property Manager</field>
        <field name="category_id" ref="property_category"/>
        <field name="implied_ids" eval="[(4, ref('property_agent_group'))]"/>
        <field name="comment">Full access to all properties and contracts</field>
    </record>

    <!-- ========================================= -->
    <!-- RECORD RULES - PROPERTY (real_state) -->
    <!-- ========================================= -->

    <!-- Agent: Only own properties -->
    -<record id="property_rule_agent" model="ir.rule">
        <field name="name">Property Agent Rule</field>
        <field name="model_id" ref="model_real_state"/>
        <field name="domain_force">[('agent', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('property_agent_group'))]"/>
        <field name="global" eval="True"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Manager: All properties -->
    <record id="property_rule_manager_all" model="ir.rule">
        <field name="name">Property: Manager All Records</field>
        <field name="model_id" ref="model_real_state"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('property_manager_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ========================================= -->
    <!-- RECORD RULES - CONTRACT -->
    <!-- ========================================= -->

    <!-- Agent: Only contracts for own properties -->
    <record id="contract_rule_agent_own" model="ir.rule">
        <field name="name">Contract: Agent Own Records</field>
        <field name="model_id" ref="model_property_contract"/>
        <field name="domain_force">[('property_id.agent', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('property_agent_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Manager: All contracts -->
    <record id="contract_rule_manager_all" model="ir.rule">
        <field name="name">Contract: Manager All Records</field>
        <field name="model_id" ref="model_property_contract"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('property_manager_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ========================================= -->
    <!-- ACCESS RIGHTS (ir.model.access.csv) -->
    <!-- ========================================= -->
    <!-- These go in security/ir.model.access.csv file -->

</odoo>
<odoo>
    <record id="real_state_view" model="ir.ui.view" >
        <field name="name">real.state.tree.view</field>
        <field name="model">real.state</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="property_type"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="real_state_form_view" model="ir.ui.view">
        <field name="name">real.state.form.view</field>
        <field name="model">real.state</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <widget name="web_ribbon" title="Sold" bg_color="text-bg-success" invisible="status != 'sold'"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="status != 'archived'"/>
                    <field name="status" widget="statusbar"/>

                    <button name="%(property_history_action)d" type="action" class="oe_stat_button" icon="fa-history">
                        <field name="history_count" widget="statinfo"/>
                    </button>

                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="reference"/>
                            <field name="property_type"/>
                        </group>
                        <group>
                            <field name="Owner"/>
                            <field name="agent"/>
                            <field name="price"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
                <chatter class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_change_status_server" model="ir.actions.server">
        <field name="name">Change Status</field>
        <field name="model_id" ref="model_real_state"/>
        <field name="binding_model_id" ref="model_real_state"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">
            action = {
                'type': 'ir.actions.act_window',
                'name': 'Change Status',
                'res_model': 'change.status',
                'view_mode': 'form',
                'target': 'new',
                'context': {
                    'default_property_id': record.id,
                }
            }
        </field>
    </record>

    <record id="reals_search_view" model="ir.ui.view" >
        <field name="name">reals.search.view</field>
        <field name="model">real.state</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_type"/>
                <filter name="villa" string="Group By Property Type" context="{'group_by':'property_type'}"/>
                <filter name="status" string="Group By Property New Status" context="{'group_by':'status'}"/>
                <filter name="client" string="Group By Client" context="{'group_by':'name'}"/>
                <filter name="agents" string="Group By Agent" context="{'group_by':'agent'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="real_action" model="ir.actions.act_window">
        <field name="name">Real State</field>
        <field name="res_model">real.state</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="real_menu_item"
        parent="real_state_root_menu"
        name="Properties"
        action="real_action"
        sequence="10"
    />
</odoo>
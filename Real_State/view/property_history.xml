<odoo>
    <record id="property_history_tree_view" model="ir.ui.view" >
        <field name="name">property.history.view</field>
        <field name="model">property.history</field>
        <field name="arch" type="xml">
            <list multi_edit="1" create="0" delete="0" edit="0">
                <field name="user_id"/>
                <field name="client_name"/>
                <field name="property_type"/>
                <field name="old_state"/>
                <field name="new_state"/>
            </list>
        </field>
    </record>
    <record id="property_history_form_view" model="ir.ui.view" >
        <field name="name">property.history.view</field>
        <field name="model">property.history</field>
        <field name="arch" type="xml">
            <form  string="Status Change History" create="0" delete="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" string="User"/>
                            <field name="client_name" string="Client Name"/>
                            <field name="property_type"/>
                            <field name="reason" string="Reason"/>
                        </group>
                        <group>
                            <field name="old_state" string="Old State"/>
                            <field name="new_state" string="New State"/>
                            <field name="create_date" string="Date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_search_view" model="ir.ui.view" >
        <field name="name">property.search.view</field>
        <field name="model">property.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="client_name"/>
                <field name="property_type"/>
                <filter name="villa" string="Group By Property Type" context="{'group_by':'property_type'}"/>
                <filter name="status" string="Group By Property New Status" context="{'group_by':'new_state'}"/>
            </search>
        </field>
    </record>


    <record id="property_history_action" model="ir.actions.act_window">
        <field name="name">History</field>
        <field name="res_model">property.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="property_history"
        parent="real_state_root_menu"
        name="History"
        action="property_history_action"
        sequence="30"
    />
</odoo>
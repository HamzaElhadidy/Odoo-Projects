<odoo>
     <record id="wizard_change_status_form_view" model="ir.ui.view" >
        <field name="name">Change Status View</field>
        <field name="model">change.status</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="property_id" invisible="1"/>
                    <field name="status" required="1"/>
                    <field name="reason" required="1"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="change_status" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="change_status_wizard_action" model="ir.actions.act_window">
        <field name="name">Change Status</field>
        <field name="res_model">change.status</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_property_id': active_id}</field>
    </record>


</odoo>
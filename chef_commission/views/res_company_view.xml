<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_company_form_chef_commission" model="ir.ui.view">
        <field name="name">res.company.form.chef.commission</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <!--
                Commission Account is now visible for ALL companies —
                no attrs restriction. Each company sets its own account.
            -->
            <field name="currency_id" position="after">
                <field name="commission_account_id"
                       string="Commission Account"
                       domain="[('deprecated', '=', False)]"
                       options="{'no_create': True}"/>
            </field>

        </field>
    </record>

</odoo>
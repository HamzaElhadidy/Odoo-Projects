<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_chef_commission" model="ir.ui.view">
        <field name="name">account.move.form.chef.commission</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="chef_commission_enabled" invisible="1"/>

                <field name="chef_id"
                       readonly="1"
                       attrs="{'invisible': [('chef_commission_enabled', '=', False)]}"/>
            </xpath>

        </field>
    </record>
</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="ir_cron_check_commission_payment" model="ir.cron">
        <field name="name">Chef Commission: Check Bill Payment Status</field>
        <field name="model_id" ref="model_chef_commission"/>
        <field name="state">code</field>
        <field name="code">model._check_bill_payment_status_all()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_auto_payment" model="ir.cron">
        <field name="name">Chef Commission: Auto Payment Scheduler</field>
        <field name="model_id" ref="model_chef_commission"/>
        <field name="state">code</field>
        <field name="code">model._scheduler_auto_payment()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

</odoo>